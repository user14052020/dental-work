APP_NAME=Dental Lab Platform
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-super-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
POSTGRES_DB=dental_lab
POSTGRES_USER=dental_lab
POSTGRES_PASSWORD=dental_lab
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
DATABASE_URL=postgresql+asyncpg://dental_lab:dental_lab@127.0.0.1:5433/dental_lab
REDIS_URL=redis://127.0.0.1:6379/1
ELASTICSEARCH_URL=http://127.0.0.1:9200
ELASTICSEARCH_CLIENTS_INDEX=dental_clients
ELASTICSEARCH_EXECUTORS_INDEX=dental_executors
ELASTICSEARCH_MATERIALS_INDEX=dental_materials
ELASTICSEARCH_WORKS_INDEX=dental_works
CORS_ORIGINS=http://localhost:3100,http://127.0.0.1:3100
BACKGROUND_JOBS_ENABLED=true
BACKGROUND_JOB_STARTUP_DELAY_SECONDS=15
BACKGROUND_JOB_LOCK_TTL_SECONDS=600
SEARCH_REINDEX_INTERVAL_SECONDS=3600
SEARCH_REINDEX_BATCH_SIZE=200
DASHBOARD_CACHE_REFRESH_INTERVAL_SECONDS=300
DASHBOARD_CACHE_WINDOWS=all,7d,30d
